{#
  Shared Neura brief stylesheet (Phase 4). Colors are injected from config.output.colors
  (RULE 4 — nothing hardcoded) via the ``c`` context object. WeasyPrint consumes HTML/CSS, so
  these ``.md.j2`` templates emit HTML (the SPEC §4.6 "Markdown → weasyprint" step is resolved to
  HTML because no Markdown→HTML library is permitted by SPEC §6 / RULE 3 — documented in PROGRESS).
#}
<style>
  @page {
    size: A4;
    margin: 1.8cm 1.8cm 1.6cm 1.8cm;
    @bottom-right { content: counter(page) " / " counter(pages); font-size: 8pt; color: {{ c.charcoal }}; }
    @bottom-left  { content: "{{ footer_note }}"; font-size: 8pt; color: {{ c.charcoal }}; }
  }
  * { box-sizing: border-box; }
  body { font-family: Aptos, "Segoe UI", Arial, sans-serif; color: {{ c.text_dark }};
         font-size: 10.5pt; line-height: 1.45; margin: 0; background: {{ c.white }}; }
  .head { display: flex; justify-content: space-between; align-items: flex-start;
          border-bottom: 2px solid {{ c.artifact_blue }}; padding-bottom: 8pt; margin-bottom: 8pt; }
  .head .titles { max-width: 78%; }
  h1 { font-family: "Aptos Display", Aptos, "Segoe UI", Arial, sans-serif; font-size: 21pt;
       color: {{ c.text_dark }}; margin: 0 0 3pt 0; line-height: 1.12; }
  .meta { color: {{ c.charcoal }}; font-size: 8.5pt; text-transform: uppercase; letter-spacing: 0.4pt; }
  .artifact-ribbon { display: flex; justify-content: space-between; gap: 8pt; align-items: center;
       margin: 0 0 11pt 0; padding: 5pt 8pt; background: {{ c.artifact_mist }};
       border-left: 3pt solid {{ c.artifact_teal }}; color: {{ c.artifact_blue }};
       font-size: 8.2pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.35pt; }
  .artifact-focus { margin: 0 0 7pt 0; padding: 6pt 8pt; background: {{ c.light_surface }};
       border-left: 3pt solid {{ c.artifact_gold }}; color: {{ c.charcoal }}; font-size: 9.2pt; }
  .artifact-focus span { display: block; color: {{ c.artifact_blue }}; font-size: 7.6pt;
       font-weight: 800; text-transform: uppercase; letter-spacing: 0.35pt; margin-bottom: 1pt; }
  .artifact-focus strong { font-size: 10pt; }
  .artifact-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6pt;
       margin: 0 0 10pt 0; }
  .artifact-stats div { padding: 6pt 7pt; background: {{ c.white }};
       border: 1px solid {{ c.light_surface }}; border-top: 2pt solid {{ c.artifact_teal }}; }
  .artifact-stats span { display: block; color: {{ c.artifact_blue }}; font-size: 7.4pt;
       font-weight: 800; text-transform: uppercase; letter-spacing: 0.35pt; }
  .artifact-stats strong { color: {{ c.text_dark }}; font-size: 11pt; }
  .logo { height: 26pt; }
  .bl { background: linear-gradient(90deg, {{ c.artifact_blue }} 0%, {{ c.charcoal }} 100%);
        color: {{ c.white }}; border-left: 4px solid {{ c.artifact_gold }};
        padding: 11pt 13pt; margin: 0 0 10pt 0; }
  .bl .label { font-size: 8.5pt; text-transform: uppercase; letter-spacing: 0.5pt;
               color: {{ c.artifact_mist }}; font-weight: bold; margin-bottom: 2pt; }
  .bl .text { font-size: 12pt; font-weight: 600; }
  .anchors { margin: 0 0 12pt 0; }
  .anchors .label { color: {{ c.artifact_blue }}; font-size: 8.5pt; font-weight: 700;
       text-transform: uppercase; letter-spacing: 0.35pt; margin-bottom: 4pt; }
  .anchor-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6pt; }
  .anchor { min-height: 35pt; padding: 7pt; background: {{ c.artifact_mist }};
       border-top: 2pt solid {{ c.artifact_gold }}; color: {{ c.text_dark }}; font-size: 8.8pt; }
  .anchor .source { display: block; margin-top: 3pt; color: {{ c.charcoal }}; font-size: 7.5pt; }
  .gap { margin: 7pt 0 10pt 0; padding: 6pt 8pt; border-left: 3pt solid {{ c.artifact_risk }};
       background: #FFF4F2; color: {{ c.artifact_risk }}; font-size: 8.8pt; font-weight: 600; }
  h2 { font-family: "Aptos Display", Aptos, "Segoe UI", Arial, sans-serif; font-size: 13pt;
       color: {{ c.artifact_blue }}; margin: 13pt 0 4pt 0; border-bottom: 1px solid {{ c.light_surface }};
       padding-bottom: 2pt; }
  p { margin: 0 0 7pt 0; }
  ul { margin: 0 0 8pt 0; padding-left: 16pt; }
  li { margin-bottom: 3pt; }
  .sources { margin-top: 4pt; font-size: 9pt; }
  .sources li { margin-bottom: 2pt; color: {{ c.charcoal }}; }
  .tier { color: {{ c.accent_cyan }}; font-weight: bold; }
  .note { font-size: 8.5pt; color: {{ c.charcoal }}; font-style: italic; margin-top: 10pt; }
</style>
