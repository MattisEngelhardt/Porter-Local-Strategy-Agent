{#
  Shared Neura brief stylesheet (Phase 4). Colors are injected from config.output.colors
  (RULE 4 — nothing hardcoded) via the ``c`` context object. WeasyPrint consumes HTML/CSS, so
  these ``.md.j2`` templates emit HTML (the SPEC §4.6 "Markdown → weasyprint" step is resolved to
  HTML because no Markdown→HTML library is permitted by SPEC §6 / RULE 3 — documented in PROGRESS).
#}
<style>
  @page {
    size: A4;
    margin: 1.8cm 1.8cm 1.6cm 1.8cm;
    @bottom-right { content: counter(page) " / " counter(pages); font-size: 8pt; color: {{ c.charcoal }}; }
    @bottom-left  { content: "{{ footer_note }}"; font-size: 8pt; color: {{ c.charcoal }}; }
  }
  * { box-sizing: border-box; }
  body { font-family: Arial, "Helvetica Neue", sans-serif; color: {{ c.text_dark }};
         font-size: 10.5pt; line-height: 1.45; margin: 0; }
  .head { display: flex; justify-content: space-between; align-items: flex-start;
          border-bottom: 2px solid {{ c.accent_cyan }}; padding-bottom: 8pt; margin-bottom: 12pt; }
  .head .titles { max-width: 78%; }
  h1 { font-size: 19pt; color: {{ c.text_dark }}; margin: 0 0 3pt 0; line-height: 1.2; }
  .meta { color: {{ c.charcoal }}; font-size: 8.5pt; text-transform: uppercase; letter-spacing: 0.4pt; }
  .logo { height: 26pt; }
  .bl { background: {{ c.light_surface }}; border-left: 4px solid {{ c.accent_cyan }};
        padding: 9pt 12pt; margin: 0 0 14pt 0; }
  .bl .label { font-size: 8.5pt; text-transform: uppercase; letter-spacing: 0.5pt;
               color: {{ c.accent_cyan }}; font-weight: bold; margin-bottom: 2pt; }
  .bl .text { font-size: 11.5pt; }
  h2 { font-size: 12.5pt; color: {{ c.accent_cyan }}; margin: 13pt 0 4pt 0;
       border-bottom: 1px solid {{ c.light_surface }}; padding-bottom: 2pt; }
  p { margin: 0 0 7pt 0; }
  ul { margin: 0 0 8pt 0; padding-left: 16pt; }
  li { margin-bottom: 3pt; }
  .sources { margin-top: 4pt; font-size: 9pt; }
  .sources li { margin-bottom: 2pt; color: {{ c.charcoal }}; }
  .tier { color: {{ c.accent_cyan }}; font-weight: bold; }
  .note { font-size: 8.5pt; color: {{ c.charcoal }}; font-style: italic; margin-top: 10pt; }
</style>
