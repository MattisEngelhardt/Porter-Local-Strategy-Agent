{#
  Shared brief building blocks (Phase 4 · Porter Editorial Block 3). The agent's analysis is
  format-agnostic (title / bottom_line / sections / sources); these macros lay it out
  professionally. The header lives in the ``_head.md.j2`` partial (included, so it reads the
  injected design tokens directly). ``body_html``, ``chart_svg`` and ``logo_data_uri`` are
  pre-built + trusted in Python, so they are marked ``| safe``; all other values are auto-escaped.
#}
{% macro bottomline(label, text) -%}
<div class="bl">
  <div class="label">{{ label }}</div>
  <div class="text">{{ text }}</div>
</div>
{%- endmacro %}

{% macro artifactframe(
  artifact_label,
  artifact_type,
  artifact_audience,
  evidence_label,
  evidence_anchors,
  gap_note,
  artifact_focus_label="",
  artifact_focus="",
  proof_stat_label="",
  proof_stat="",
  source_stat_label="",
  source_stat="",
  gap_stat_label="",
  gap_stat=""
) -%}
<div class="artifact-ribbon">
  <span>{{ artifact_label }}</span>
  <span>{{ artifact_type }} · {{ artifact_audience }}</span>
</div>
{% if artifact_focus %}
<div class="artifact-focus">
  <span>{{ artifact_focus_label }}</span>
  <strong>{{ artifact_focus }}</strong>
</div>
{% endif %}
<div class="artifact-stats">
  <div><span>{{ proof_stat_label }}</span><strong>{{ proof_stat }}</strong></div>
  <div><span>{{ source_stat_label }}</span><strong>{{ source_stat }}</strong></div>
  <div><span>{{ gap_stat_label }}</span><strong>{{ gap_stat }}</strong></div>
</div>
{% if evidence_anchors %}
<div class="anchors">
  <div class="label">{{ evidence_label }}</div>
  <div class="anchor-grid">
  {% for anchor in evidence_anchors %}
    <div class="anchor"><span class="idx">[{{ "%02d" | format(loop.index) }}]</span>{{ anchor.text }}{% if anchor.source %}<span class="source">{{ anchor.source }}</span>{% endif %}</div>
  {% endfor %}
  </div>
</div>
{% endif %}
{% if gap_note %}<div class="gap">{{ gap_note }}</div>{% endif %}
{%- endmacro %}

{% macro sections(items) -%}
{% for s in items %}
<h2>{{ s.heading }}</h2>
{{ s.body_html | safe }}
{% if s.chart_svg %}<figure class="chart">{{ s.chart_svg | safe }}</figure>{% endif %}
{% endfor %}
{%- endmacro %}

{% macro sources(label, items) -%}
{% if items %}
<h2>{{ label }}</h2>
<ul class="sources">
{% for src in items %}
  <li>{{ src.url }}{% if src.title %} — {{ src.title }}{% endif %}{% if src.date %} ({{ src.date }}){% endif %}{% if src.tier %} <span class="tier">[{{ src.tier }}]</span>{% endif %}</li>
{% endfor %}
</ul>
{% endif %}
{%- endmacro %}
