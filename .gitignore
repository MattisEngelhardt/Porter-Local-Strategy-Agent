# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Agent brain — local only, may contain confidential Neura context (SPEC N-9)
brain.md

# Personal planning / spec / workflow docs — local only, never publish
strategy_agent_SPEC.md
opus_WORKFLOW.md
PHASE_3.5_PLAN.md
PHASE_4_KICKOFF.md
PHASE_5_KICKOFF.md
DESIGN_REVAMP_PROGRESS.md
demo_prompt.txt

# Generated outputs (keep the directory, ignore its contents by default).
# Outputs may contain confidential context, so nothing is published unless
# explicitly whitelisted below. Curated demo examples (one per format) are
# committed so the deliverables are viewable on GitHub.
output/*
!output/.gitkeep
!output/.best_demo.json
!output/2026-06-03_preparing_a_comprehensive_board_grade_presentation_deck.pptx
!output/2026-06-01_competitive_analysis_figure_ai_strategic_threat_an_brief.pdf
!output/2026-06-01_develop_a_comprehensive_business_case_analyzing_th_business_case.xlsx
!output/2026-05-31_q2_2026_performance_review_financial_health_and_st_briefing.md

# Persistent memory store (keep the directory, ignore its contents)
data/chroma_db/*
!data/chroma_db/.gitkeep

# Research result cache (diskcache SQLite, Phase 2) — local only
data/cache/

# Machine-specific porter pre-launch hook (e.g. auto-start LM Studio) — local only
porter.local.ps1

# Editorial OFL fonts — fetched locally via `scripts/install_fonts.py`, not vendored as binaries
# (REQ-1/2: local/free/OFL). Absent dir → renderers degrade to system fonts (REQ-5). README stays.
assets/fonts/*.ttf
assets/fonts/*.otf
assets/fonts/*.woff
assets/fonts/*.woff2
assets/fonts/*-OFL.txt

# Throwaway Block-4 verification drivers (local-only smoke tests, not part of the suite)
scripts/_*.py

# Logs
logs/

# Secrets (no external keys needed, but never commit)
.env

# SearXNG runtime data (Phase 2); keep generic trust-hook docs/code tracked.
searxng-data/*
!searxng-data/certs/
searxng-data/certs/*
!searxng-data/certs/README.md
!searxng-data/python/
!searxng-data/python/sitecustomize.py

# Docker tutorial (not part of the project)
welcome-to-docker/
.git_commit_msg.txt
